COMPOSE_PROJECT_NAME=laravel-{{ toKebabCase PackageName }}

REGISTRY_HOST=ghcr.io
REGISTRY_PATH=specsnl
IMAGE_REGISTRY_PHP=${REGISTRY_HOST}/${REGISTRY_PATH}/php{{ PhpVersion | replace "." "" }}
{{ if eq PhpVersion "8.4" }}
IMAGE_TAG_PHP=builder_nodejs-1.5.0
{{ else if eq PhpVersion "8.3" }}
IMAGE_TAG_PHP=builder_nodejs-1.8.0
{{ else }}
IMAGE_TAG_PHP=builder_nodejs-0.5.0
{{- end }}
