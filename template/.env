COMPOSE_PROJECT_NAME=laravel-{{ kebabcase PackageName }}

REGISTRY_HOST=ghcr.io
REGISTRY_PATH=specsnl
{{if eq PhpVersion "8.4"}}
IMAGE_REGISTRY_PHP=${REGISTRY_HOST}/${REGISTRY_PATH}/php84
IMAGE_TAG_PHP=builder_nodejs-1.5.0
{{else if eq PhpVersion "8.3"}}
IMAGE_REGISTRY_PHP=${REGISTRY_HOST}/${REGISTRY_PATH}/php83
IMAGE_TAG_PHP=builder_nodejs-1.8.0
{{else}}
IMAGE_REGISTRY_PHP=${REGISTRY_HOST}/${REGISTRY_PATH}/php85
IMAGE_TAG_PHP=builder_nodejs-0.5.0
{{- end}}
